#!/usr/bin/env bash

set -euo pipefail

REAL_CODEX="${SULION_REAL_CODEX:-}"
if [[ -z "${REAL_CODEX}" ]]; then
  echo "sulion codex wrapper: SULION_REAL_CODEX is not set" >&2
  exit 1
fi

if [[ -z "${SULION_PTY_ID:-}" ]]; then
  exec "${REAL_CODEX}" "$@"
fi

SESSIONS_DIR="${SULION_CODEX_SESSIONS:-${HOME:-/home/dev}/.codex/sessions}"
CORRELATE_SOCK="${SULION_CORRELATE_SOCK:-/run/sulion/correlate.sock}"

exec /usr/local/bin/sulion codex-launcher \
  --codex-bin "${REAL_CODEX}" \
  --pty-id "${SULION_PTY_ID}" \
  --sessions-dir "${SESSIONS_DIR}" \
  --correlate-sock "${CORRELATE_SOCK}" \
  -- "$@"
